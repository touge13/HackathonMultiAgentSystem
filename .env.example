OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Agent
MODEL_ORCHESTOR="openai/gpt-5.4-nano"
OPENROUTER_ENABLE_REASONING=0
MODEL_AGENT="openai/gpt-5.4-nano"

AVAILABLE_AGENTS=StructureAnalyzer,SynthesisProtocolSearchAgent,LiteratureRAGAgent,FINISH
SUPERVISOR_TIMEOUT_SECONDS=45
AGENT_TIMEOUT_SECONDS=60
GRAPH_RECURSION_LIMIT=25
LOG_VALUE_MAX_CHARS=1200

# Web-search
MODEL_WEB_SEARCH="openai/gpt-5.4-nano"

SERPAPI_KEY=

LITERATURE_WEB_QUERY_MAX_CHARS=180
PREFER_SEARCH_BACKEND=neurosearch

# RAG
RERANK_MODEL="openai/gpt-5.4-nano"
ANSWER_MODEL="openai/gpt-5.4-nano"